# ==============================================
# Architectural Drawings London — API Environment
# ==============================================

# Server
NODE_ENV=production
PORT=3001
ALLOWED_ORIGIN=https://www.architecturaldrawings.uk

# Database (SQLite file path; swap for Postgres URL in production)
DATABASE_URL=./data/ad.sqlite

# JWT
JWT_SECRET=CHANGE_ME_TO_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=7d

# Sentry
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2

# Stripe (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_SUCCESS_URL=https://www.architecturaldrawings.uk/portal/dashboard.html?payment=success
STRIPE_CANCEL_URL=https://www.architecturaldrawings.uk/portal/dashboard.html?payment=cancelled

# Email (SMTP — e.g. SendGrid, Postmark, Mailgun, AWS SES)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="Architectural Drawings <noreply@architecturaldrawings.uk>"
EMAIL_TO_OPS=hello@architecturaldrawings.uk

# Resend (used for callback form notifications)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# File storage — local path (swap for S3/R2 URL in production)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=100

# Rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
